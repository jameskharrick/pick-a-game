{
  "buildCommand": "npm run build --prefix client",
  "outputDirectory": "client/dist",
  "functions": {
    "server/index.js": {}
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/server/index" },
    { "source": "/auth/:path*", "destination": "/server/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
